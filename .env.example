# Android APK Signing Credentials
# Copy this file to .env and fill in your actual values
# .env is ignored by git and should NEVER be committed

# Keystore path (relative to src-tauri/)
TAURI_ANDROID_KEYSTORE_PATH=../../apk key/Singularitydeux/Singularitydeux

# Keystore password
TAURI_ANDROID_KEYSTORE_PASSWORD=your_keystore_password_here

# Key alias
TAURI_ANDROID_KEY_ALIAS=singularitydeux

# Key password
TAURI_ANDROID_KEY_PASSWORD=your_key_password_here
